---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const projects = (await getCollection('projects'))
	.filter((p) => p.data.published)
	.filter((p) => p.data.highlight)
	.sort((a, b) => (b.data.pubDate?.getTime() || 0) - (a.data.pubDate?.getTime() || 0))
	.slice(0, 3);

const changelogs = (await getCollection('changelog'))
	.filter((c) => c.data.published)
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 3);

const posts = (await getCollection('blog'))
	.filter((post) => post.data.published)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.hero {
				padding: 2.25rem 0 1.5rem;
			}
			.hero h1 {
				font-size: 2.9rem;
				margin-bottom: 0.4rem;
			}
			.hero p {
				max-width: 62ch;
				color: rgb(var(--gray));
				margin: 0;
			}
			section {
				margin-top: 2rem;
			}
			.section-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1rem;
			}
			.section-head h2 {
				font-size: 1.35rem;
				margin: 0;
			}
			.section-head a {
				font-size: 0.9rem;
				white-space: nowrap;
			}
			.post-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.25rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-grid li:first-child {
				grid-column: 1 / -1;
			}
			.post-card {
				display: block;
				text-decoration: none;
			}
			.post-card img {
				width: 100%;
				aspect-ratio: 2 / 1;
				object-fit: cover;
				margin-bottom: 0.65rem;
				border-radius: 8px;
			}
			.post-card h3 {
				font-size: 1.2rem;
				margin-bottom: 0.25rem;
			}
			.post-card p {
				color: rgb(var(--gray));
				margin: 0;
				font-size: 0.95rem;
			}
			.date {
				color: rgb(var(--gray));
				font-size: 0.9rem;
				margin: 0 0 0.35rem;
			}
			.meta-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 0.75rem;
			}
			.meta-list li {
				padding-bottom: 0.75rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.meta-list li:last-child {
				border-bottom: 0;
				padding-bottom: 0;
			}
			.meta-list h3 {
				font-size: 1.05rem;
				margin-bottom: 0.15rem;
			}
			.meta-list p {
				font-size: 0.92rem;
				color: rgb(var(--gray));
				margin: 0;
			}
			.status-badge {
				font-size: 0.72em;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				padding: 0.1em 0.55em;
				border-radius: 99px;
				margin-left: 0.4rem;
				vertical-align: middle;
			}
			.status-badge.shipping { background: #d1fae5; color: #065f46; }
			.status-badge.active { background: #ede9fe; color: #4c1d95; }
			.status-badge.new { background: #dbeafe; color: #1e3a8a; }
			.status-badge.update { background: #fef3c7; color: #92400e; }
			@media (max-width: 720px) {
				main {
					width: min(100%, calc(100% - 1rem));
				}
				.hero {
					padding-top: 1.25rem;
				}
				.hero h1 {
					font-size: 2.2rem;
				}
				.section-head {
					flex-direction: column;
					align-items: flex-start;
					gap: 0.25rem;
				}
				.post-grid {
					grid-template-columns: 1fr;
				}
				.post-grid li:first-child {
					grid-column: auto;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>{SITE_TITLE}</h1>
				<p>{SITE_DESCRIPTION}</p>
			</section>

			<section aria-labelledby="posts-heading">
				<div class="section-head">
					<h2 id="posts-heading">Latest Posts</h2>
					<a href="/blog">View all</a>
				</div>
				<ul class="post-grid">
					{posts.map((post) => (
						<li>
							<a class="post-card" href={`/blog/${post.id}/`}>
								<img src={post.data.heroImage} alt="" width="720" height="360" />
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
							</a>
						</li>
					))}
				</ul>
			</section>

			<section aria-labelledby="projects-heading">
				<div class="section-head">
					<h2 id="projects-heading">Projects</h2>
					<a href="/projects">View all</a>
				</div>
				<ul class="meta-list">
					{projects.map((project) => (
						<li>
							<h3>
								<a href={project.data.url || project.data.repo || '#'} target={project.data.url ? '_blank' : undefined}>
									{project.data.title}
								</a>
								<span class={`status-badge ${project.data.status}`}>{project.data.status}</span>
							</h3>
							<p>{project.data.description}</p>
						</li>
					))}
				</ul>
			</section>

			<section aria-labelledby="shipping-heading">
				<div class="section-head">
					<h2 id="shipping-heading">Shipping</h2>
					<a href="/changelog">View all</a>
				</div>
				<ul class="meta-list">
					{changelogs.map((item) => (
						<li>
							<p class="date">
								<FormattedDate date={item.data.pubDate} />
							</p>
							<h3>
								<a href={item.data.repo || '#'} target={item.data.repo ? '_blank' : undefined}>
									{item.data.title}
								</a>
								<span class={`status-badge ${item.data.changeType}`}>{item.data.changeType}</span>
							</h3>
							<p>{item.data.description}</p>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
