---
export const prerender = false;
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="robots" content="noindex" />
	<title>R2 Media — bbfans</title>
	<style>
		:root {
			color-scheme: light;
			--bg: #f7f8fb;
			--panel: #ffffff;
			--text: #151923;
			--muted: #5f6b7a;
			--line: #dfe4ec;
			--accent: #2347d7;
			--danger: #b42318;
		}
		* {
			box-sizing: border-box;
		}
		body {
			margin: 0;
			background: var(--bg);
			color: var(--text);
			font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
			font-size: 16px;
			line-height: 1.5;
		}
		header,
		main {
			width: min(1120px, calc(100% - 2rem));
			margin: 0 auto;
		}
		header {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 1rem;
			padding: 1.25rem 0;
		}
		h1 {
			margin: 0;
			font-size: 1.35rem;
		}
		.toolbar,
		.auth-panel {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			flex-wrap: wrap;
			padding: 1rem;
			background: var(--panel);
			border: 1px solid var(--line);
			border-radius: 8px;
		}
		.auth-panel {
			align-items: flex-start;
			flex-direction: column;
			margin-bottom: 1rem;
		}
		.toolbar {
			justify-content: space-between;
			margin-bottom: 1rem;
		}
		.actions {
			display: flex;
			align-items: center;
			gap: 0.6rem;
			flex-wrap: wrap;
		}
		button,
		.button {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-height: 40px;
			padding: 0.5rem 0.8rem;
			border: 1px solid var(--line);
			border-radius: 6px;
			background: #fff;
			color: var(--text);
			font: inherit;
			text-decoration: none;
			cursor: pointer;
		}
		button.primary,
		.button.primary {
			border-color: var(--accent);
			background: var(--accent);
			color: #fff;
		}
		button.danger {
			color: var(--danger);
		}
		button:disabled {
			cursor: not-allowed;
			opacity: 0.55;
		}
		input[type="file"] {
			max-width: 100%;
		}
		.meta {
			color: var(--muted);
			font-size: 0.92rem;
		}
		.status {
			min-height: 1.5rem;
			color: var(--muted);
		}
		.status.error {
			color: var(--danger);
		}
		.grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
			gap: 1rem;
			padding-bottom: 3rem;
		}
		.card {
			overflow: hidden;
			background: var(--panel);
			border: 1px solid var(--line);
			border-radius: 8px;
		}
		.preview {
			display: grid;
			place-items: center;
			aspect-ratio: 4 / 3;
			background: #eef2f7;
		}
		.preview img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
		.file {
			padding: 0.75rem;
		}
		.filename {
			overflow-wrap: anywhere;
			font-weight: 700;
			font-size: 0.9rem;
		}
		.card-actions {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.5rem;
			margin-top: 0.75rem;
		}
		.empty {
			padding: 2rem;
			background: var(--panel);
			border: 1px dashed var(--line);
			border-radius: 8px;
			color: var(--muted);
			text-align: center;
		}
		@media (max-width: 680px) {
			header {
				align-items: flex-start;
				flex-direction: column;
			}
			.toolbar {
				align-items: stretch;
				flex-direction: column;
			}
			.actions {
				align-items: stretch;
				flex-direction: column;
			}
			button,
			.button {
				width: 100%;
			}
			.grid {
				grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
			}
		}
	</style>
</head>
<body>
	<header>
		<div>
			<h1>R2 Media</h1>
			<div class="meta">Bucket: blog-images-1001020 · Prefix: blog-img/</div>
		</div>
		<a class="button" href="/admin/">Back to CMS</a>
	</header>

	<main>
		<section class="auth-panel" id="auth-panel" hidden>
			<strong>GitHub login required</strong>
			<div class="meta">Use the same GitHub OAuth login as the CMS. The media API checks repository write access before reading or changing R2.</div>
			<a class="button primary" href="/api/auth" target="_blank">Login with GitHub</a>
		</section>

		<section class="toolbar">
			<div>
				<strong>Images</strong>
				<div class="meta" id="summary">Loading media...</div>
			</div>
			<div class="actions">
				<input id="file-input" type="file" accept="image/*" />
				<button class="primary" id="upload-button" type="button">Upload</button>
				<button id="refresh-button" type="button">Refresh</button>
			</div>
		</section>
		<div class="status" id="status" role="status"></div>
		<section class="grid" id="media-grid" aria-live="polite"></section>
	</main>

	<script>
		const grid = document.querySelector("#media-grid");
		const statusEl = document.querySelector("#status");
		const summaryEl = document.querySelector("#summary");
		const authPanel = document.querySelector("#auth-panel");
		const fileInput = document.querySelector("#file-input");
		const uploadButton = document.querySelector("#upload-button");
		const refreshButton = document.querySelector("#refresh-button");

		function setStatus(message, isError = false) {
			statusEl.textContent = message;
			statusEl.classList.toggle("error", isError);
		}

		function token() {
			return localStorage.getItem("decap-cms-user") || localStorage.getItem("netlify-cms-user");
		}

		function accessToken() {
			const raw = token();
			if (!raw) return "";
			try {
				const parsed = JSON.parse(raw);
				return parsed.token || parsed.backend?.token || parsed.auth_token || "";
			} catch {
				return "";
			}
		}

		function formatBytes(size) {
			if (!Number.isFinite(size)) return "";
			if (size < 1024) return `${size} B`;
			if (size < 1024 * 1024) return `${(size / 1024).toFixed(1)} KB`;
			return `${(size / 1024 / 1024).toFixed(1)} MB`;
		}

		function filename(key) {
			return key.split("/").pop() || key;
		}

		function render(objects) {
			grid.innerHTML = "";
			summaryEl.textContent = `${objects.length} file${objects.length === 1 ? "" : "s"} in R2`;

			if (objects.length === 0) {
				const empty = document.createElement("div");
				empty.className = "empty";
				empty.textContent = "No images found in blog-images-1001020/blog-img/. Upload an image to create the first object.";
				grid.append(empty);
				return;
			}

			for (const item of objects) {
				const card = document.createElement("article");
				card.className = "card";

				const preview = document.createElement("div");
				preview.className = "preview";
				const image = document.createElement("img");
				image.src = item.url;
				image.alt = "";
				preview.append(image);

				const file = document.createElement("div");
				file.className = "file";
				const name = document.createElement("div");
				name.className = "filename";
				name.textContent = filename(item.key);
				const meta = document.createElement("div");
				meta.className = "meta";
				meta.textContent = `${formatBytes(item.size)}${item.uploaded ? ` · ${new Date(item.uploaded).toLocaleDateString()}` : ""}`;

				const actions = document.createElement("div");
				actions.className = "card-actions";
				const copy = document.createElement("button");
				copy.type = "button";
				copy.textContent = "Copy URL";
				const remove = document.createElement("button");
				remove.type = "button";
				remove.className = "danger";
				remove.textContent = "Delete";

				copy.addEventListener("click", async () => {
					await navigator.clipboard.writeText(item.url);
					setStatus(`Copied ${item.url}`);
				});
				remove.addEventListener("click", async () => {
					if (!confirm(`Delete ${item.key}?`)) return;
					await deleteMedia(item.key);
				});

				actions.append(copy, remove);
				file.append(name, meta, actions);
				card.append(preview, file);
				grid.append(card);
			}
		}

		async function requestMedia(path, options = {}) {
			const token = accessToken();
			authPanel.hidden = Boolean(token);
			if (!token) {
				throw new Error("Login with GitHub first, then refresh this page.");
			}

			const response = await fetch(path, {
				...options,
				headers: {
					...(options.headers || {}),
					Authorization: `Bearer ${token}`,
				},
			});
			const data = await response.json().catch(() => ({}));
			if (!response.ok) {
				throw new Error(data.error || `Request failed with ${response.status}`);
			}
			return data;
		}

		async function loadMedia() {
			setStatus("Loading R2 media...");
			try {
				const data = await requestMedia("/api/media");
				render(data.objects || []);
				setStatus("");
			} catch (error) {
				grid.innerHTML = "";
				summaryEl.textContent = "Could not load media";
				setStatus(error.message, true);
			}
		}

		async function uploadMedia() {
			const file = fileInput.files?.[0];
			if (!file) {
				setStatus("Choose an image first.", true);
				return;
			}

			uploadButton.disabled = true;
			setStatus(`Uploading ${file.name}...`);
			try {
				const formData = new FormData();
				formData.append("file", file);
				const data = await requestMedia("/api/media", {
					method: "PATCH",
					body: formData,
				});
				await navigator.clipboard.writeText(data.url);
				fileInput.value = "";
				setStatus(`Uploaded and copied ${data.url}`);
				await loadMedia();
			} catch (error) {
				setStatus(error.message, true);
			} finally {
				uploadButton.disabled = false;
			}
		}

		async function deleteMedia(key) {
			setStatus(`Deleting ${key}...`);
			try {
				await requestMedia(`/api/media?key=${encodeURIComponent(key)}`, {
					method: "DELETE",
				});
				setStatus(`Deleted ${key}`);
				await loadMedia();
			} catch (error) {
				setStatus(error.message, true);
			}
		}

		window.addEventListener("message", (event) => {
			if (typeof event.data !== "string") return;
			if (event.data === "authorizing:github") {
				event.source?.postMessage("authorizing:github", event.origin);
				return;
			}
			if (!event.data.startsWith("authorization:github:success:")) return;

			const payload = JSON.parse(event.data.replace("authorization:github:success:", ""));
			localStorage.setItem("decap-cms-user", JSON.stringify({ token: payload.token }));
			authPanel.hidden = true;
			loadMedia();
		});

		uploadButton.addEventListener("click", uploadMedia);
		refreshButton.addEventListener("click", loadMedia);
		loadMedia();
	</script>
</body>
</html>
