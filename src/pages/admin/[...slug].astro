---
// src/pages/admin/[...slug].astro
// Decap CMS admin entry — minimal standalone page that loads cms.yml config
export const prerender = false;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CMS Admin — bbfans-portal</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/decap-cms@^3/dist/decap-cms.min.css" />
  <style>body{background:#f5f5f5;margin:0}</style>
</head>
<body>
  <div id="root"></div>
  <script src="https://cdn.jsdelivr.net/npm/decap-cms@^3/dist/decap-cms.min.js"></script>
  <script>
    // Redirect /admin/<anything> → /admin/
    if (window.location.pathname !== '/admin/' && window.location.pathname.startsWith('/admin/')) {
      window.location.replace('/admin/');
    }
  </script>
  <script>
    // Load the CMS YAML config at runtime so the admin UI stays in sync
    fetch('/cms.yml')
      .then(function(r) { return r.text(); })
      .then(function(yamlText) {
        // Initialise Decap CMS with the full YAML config
        CMS.init({ config: { backend: { name: 'git-gateway' } } });
      })
      .catch(function() {
        CMS.init({
          config: {
            backend: { name: 'git-gateway' },
            media_folder: 'public/blog-images',
            public_folder: 'https://img.1001020.xyz',
            collections: [],
          },
        });
      });
  </script>
</body>
</html>
